# RecEngine Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Deployment Configuration
# ===========================================
# Options: shadow, canary, ab_test
DEPLOYMENT_MODE=ab_test

# Traffic split ratio for A/B testing (0.0 to 1.0)
# Only used when DEPLOYMENT_MODE=ab_test
SPLIT_RATIO=0.5

# ===========================================
# MLflow Configuration
# ===========================================
# MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment names (optional, defaults used if not set)
# MLFLOW_EXPERIMENT_MODEL_A=recengine-model-a
# MLFLOW_EXPERIMENT_MODEL_B=recengine-model-b
# MLFLOW_EXPERIMENT_MODEL_C=recengine-model-c

# ===========================================
# Data Configuration
# ===========================================
# Minimum number of interactions per user/item
MIN_INTERACTIONS=10

# Test set ratio (temporal split)
TEST_RATIO=0.2

# ===========================================
# Model Configuration
# ===========================================
# Model A (ALS) hyperparameters
# MODEL_A_N_FACTORS=100
# MODEL_A_N_EPOCHS=20
# MODEL_A_REGULARIZATION=0.01
# MODEL_A_ALPHA=40.0

# Model B (Semantic) configuration
# MODEL_B_MODEL_NAME=all-MiniLM-L6-v2

# Model C (CTR) hyperparameters
# MODEL_C_MAX_DEPTH=6
# MODEL_C_LEARNING_RATE=0.05
# MODEL_C_N_ESTIMATORS=200

# ===========================================
# API Configuration
# ===========================================
# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# ===========================================
# Monitoring Configuration
# ===========================================
# Drift detection threshold
# DRIFT_THRESHOLD=0.1

# ===========================================
# GCP Configuration (for CD)
# ===========================================
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# GCP_SERVICE_NAME=recengine

# ===========================================
# Database Configuration
# ===========================================
# For predictions/feedback logging
DATABASE_URL=sqlite:///data/predictions.db
